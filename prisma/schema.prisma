generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(50)
  employees Employee[]

  @@map("roles")
}

model Employee {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(255)
  email         String          @unique @db.VarChar(255)
  phoneNumber   String?         @map("phone_number") @db.VarChar(50)
  passwordHash  String          @map("password_hash") @db.VarChar(255)
  roleId        Int             @map("role_id")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  storeId       Int?            @map("store_id")
  locations     AgentLocation[]
  customers     Customer[]      @relation("AssignedAgent")
  deliveryPlans DeliveryPlan[]
  role          Role            @relation(fields: [roleId], references: [id])
  store         Store?          @relation(fields: [storeId], references: [id])
  orders        Order[]         @relation("AgentOrders")

  @@map("employees")
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  contactInfo String?   @map("contact_info")
  products    Product[]

  @@map("suppliers")
}

model Category {
  id            Int       @id @default(autoincrement())
  nameMongolian String    @map("name_mongolian") @db.VarChar(255)
  nameEnglish   String?   @map("name_english") @db.VarChar(255)
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  products      Product[]

  @@map("categories")
}

model Product {
  id                Int                     @id @default(autoincrement())
  nameMongolian     String                  @map("name_mongolian") @db.VarChar(255)
  nameEnglish       String?                 @map("name_english") @db.VarChar(255)
  productCode       String?                 @unique @map("product_code") @db.VarChar(100)
  supplierId        Int?                    @map("supplier_id")
  stockQuantity     Int                     @default(0) @map("stock_quantity")
  priceWholesale    Decimal?                @map("price_wholesale") @db.Decimal(10, 2)
  priceRetail       Decimal?                @map("price_retail") @db.Decimal(10, 2)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  categoryId        Int?                    @map("category_id")
  nameKorean        String?                 @map("name_korean") @db.VarChar(255)
  barcode           String?                 @db.VarChar(100)
  unitsPerBox       Int?                    @map("units_per_box")
  pricePerBox       Decimal?                @map("price_per_box") @db.Decimal(10, 2)
  netWeight         Decimal?                @map("net_weight") @db.Decimal(10, 3)
  grossWeight       Decimal?                @map("gross_weight") @db.Decimal(10, 3)
  isActive          Boolean                 @default(true) @map("is_active")
  inventoryBalances InventoryBalance[]
  forecasts         InventoryForecast[]
  orderItems        OrderItem[]
  batches           ProductBatch[]
  salesAnalytics    ProductSalesAnalytics[]
  prices            ProductPrice[]
  category          Category?               @relation(fields: [categoryId], references: [id])
  supplier          Supplier?               @relation(fields: [supplierId], references: [id])
  returns           Return[]

  @@map("products")
}

model CustomerType {
  id        Int            @id @default(autoincrement())
  typeName  String         @map("type_name") @db.VarChar(100)
  customers Customer[]
  prices    ProductPrice[]

  @@map("customer_types")
}

model Customer {
  id                 Int            @id @default(autoincrement())
  name               String         @db.VarChar(255)
  realName           String?        @map("real_name") @db.VarChar(255)
  name2              String?        @map("name_2") @db.VarChar(255)
  legacyCustomerId   Int?           @map("legacy_customer_id")
  address            String?
  phoneNumber        String?        @map("phone_number") @db.VarChar(50)
  locationLatitude   Float?         @map("location_latitude")
  locationLongitude  Float?         @map("location_longitude")
  customerTypeId     Int?           @map("customer_type_id")
  assignedAgentId    Int?           @map("assigned_agent_id")
  organizationName   String?        @map("organization_name") @db.VarChar(255)
  organizationType   String?        @map("organization_type") @db.VarChar(100)
  contactPersonName  String?        @map("contact_person_name") @db.VarChar(255)
  registrationNumber String?        @map("registration_number") @db.VarChar(100)
  district           String?        @db.VarChar(100)
  detailedAddress    String?        @map("detailed_address")
  isVatPayer         Boolean        @default(false) @map("is_vat_payer")
  paymentTerms       String?        @map("payment_terms") @db.VarChar(100)
  direction          String?        @db.VarChar(100)
  assignedAgent      Employee?      @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  customerType       CustomerType?  @relation(fields: [customerTypeId], references: [id])
  deliveryPlans      DeliveryPlan[]
  orders             Order[]
  returns            Return[]

  @@map("customers")
}

model Order {
  id                Int           @id @default(autoincrement())
  customerId        Int           @map("customer_id")
  agentId           Int           @map("agent_id")
  orderDate         DateTime      @default(now()) @map("order_date") @db.Timestamptz(3)
  status            String        @default("Pending") @db.VarChar(50)
  totalAmount       Decimal?      @map("total_amount") @db.Decimal(12, 2)
  creditTermDays    Int?          @map("credit_term_days")
  deliveryPlanId    Int?          @map("delivery_plan_id")
  dueDate           DateTime?     @map("due_date") @db.Timestamptz(3)
  paidAmount        Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentMethod     PaymentMethod @default(Cash) @map("payment_method")
  paymentStatus     PaymentStatus @default(Pending) @map("payment_status")
  remainingAmount   Decimal?      @map("remaining_amount") @db.Decimal(12, 2)
  orderType         OrderType     @default(Store) @map("order_type")
  deliveryDate      DateTime?     @map("delivery_date") @db.Timestamptz(3)
  subtotalAmount    Decimal?      @map("subtotal_amount") @db.Decimal(12, 2)
  vatAmount         Decimal?      @default(0) @map("vat_amount") @db.Decimal(12, 2)
  ebarimtId         String?       @map("ebarimt_id") @db.VarChar(100)
  ebarimtBillId     String?       @map("ebarimt_bill_id") @db.VarChar(100)
  ebarimtLottery    String?       @map("ebarimt_lottery") @db.VarChar(50)
  ebarimtQrData     String?       @map("ebarimt_qr_data")
  ebarimtRegistered Boolean       @default(false) @map("ebarimt_registered")
  ebarimtDate       DateTime?     @map("ebarimt_date") @db.Timestamptz(3)
  ebarimtReturnId   String?       @map("ebarimt_return_id") @db.VarChar(100)
  orderNumber       String?       @unique @map("order_number") @db.VarChar(50)
  orderItems        OrderItem[]
  agent             Employee      @relation("AgentOrders", fields: [agentId], references: [id])
  customer          Customer      @relation(fields: [customerId], references: [id])
  payments          Payment[]
  returns           Return[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Return {
  id          Int       @id @default(autoincrement())
  orderId     Int?      @map("order_id")
  productId   Int       @map("product_id")
  customerId  Int?      @map("customer_id")
  quantity    Int
  unitPrice   Decimal?  @map("unit_price") @db.Decimal(10, 2)
  reason      String?
  returnDate  DateTime  @default(now()) @map("return_date") @db.Timestamptz(3)
  expiryDate  DateTime? @map("expiry_date") @db.Timestamptz(3)
  notes       String?
  order       Order?    @relation(fields: [orderId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])

  @@map("returns")
}

model AgentLocation {
  id        Int      @id @default(autoincrement())
  agentId   Int      @map("agent_id")
  latitude  Float
  longitude Float
  timestamp DateTime @default(now()) @db.Timestamptz(3)
  agent     Employee @relation(fields: [agentId], references: [id])

  @@map("agent_locations")
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @map("order_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @default(now()) @map("payment_date") @db.Timestamptz(3)
  paymentMethod PaymentMethod @map("payment_method")
  notes         String?
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ProductBatch {
  id              Int       @id @default(autoincrement())
  productId       Int       @map("product_id")
  batchNumber     String    @map("batch_number") @db.VarChar(100)
  arrivalDate     DateTime  @map("arrival_date") @db.Timestamptz(3)
  expiryDate      DateTime? @map("expiry_date") @db.Timestamptz(3)
  quantity        Int
  costPrice       Decimal?  @map("cost_price") @db.Decimal(10, 2)
  supplierInvoice String?   @map("supplier_invoice") @db.VarChar(255)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, batchNumber])
  @@map("product_batches")
}

model InventoryBalance {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  month          Int
  year           Int
  openingBalance Int      @default(0) @map("opening_balance")
  closingBalance Int      @default(0) @map("closing_balance")
  totalIn        Int      @default(0) @map("total_in")
  totalOut       Int      @default(0) @map("total_out")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, month, year])
  @@map("inventory_balances")
}

model DeliveryPlan {
  id                 Int            @id @default(autoincrement())
  planDate           DateTime       @map("plan_date") @db.Timestamptz(3)
  agentId            Int            @map("agent_id")
  customerId         Int            @map("customer_id")
  orderId            Int?           @map("order_id")
  scheduledTime      DateTime?      @map("scheduled_time") @db.Timestamptz(3)
  status             DeliveryStatus @default(Planned)
  deliveryNotes      String?        @map("delivery_notes")
  actualDeliveryTime DateTime?      @map("actual_delivery_time") @db.Timestamptz(3)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  description        String?
  targetArea         String?        @map("target_area") @db.VarChar(255)
  estimatedOrders    Int?           @map("estimated_orders")
  agent              Employee       @relation(fields: [agentId], references: [id])
  customer           Customer       @relation(fields: [customerId], references: [id])

  @@map("delivery_plans")
}

model Store {
  id                Int        @id @default(autoincrement())
  name              String     @db.VarChar(255)
  address           String?
  storeType         StoreType  @map("store_type")
  locationLatitude  Float?     @map("location_latitude")
  locationLongitude Float?     @map("location_longitude")
  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  employees         Employee[]

  @@map("stores")
}

model ProductSalesAnalytics {
  id                  Int      @id @default(autoincrement())
  productId           Int      @map("product_id")
  month               Int
  year                Int
  quantitySold        Int      @default(0) @map("quantity_sold")
  averageMonthlySales Decimal  @default(0) @map("average_monthly_sales") @db.Decimal(10, 2)
  threeMonthAverage   Decimal  @default(0) @map("three_month_average") @db.Decimal(10, 2)
  sixMonthAverage     Decimal  @default(0) @map("six_month_average") @db.Decimal(10, 2)
  isOutlier           Boolean  @default(false) @map("is_outlier")
  outlierReason       String?  @map("outlier_reason")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, month, year])
  @@map("product_sales_analytics")
}

model InventoryForecast {
  id                       Int      @id @default(autoincrement())
  productId                Int      @map("product_id")
  month                    Int
  year                     Int
  recommendedOrderQuantity Int      @default(0) @map("recommended_order_quantity")
  basedOnAverage           String   @map("based_on_average") @db.VarChar(50)
  forecastDate             DateTime @default(now()) @map("forecast_date") @db.Timestamptz(3)
  notes                    String?
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  product                  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, month, year])
  @@map("inventory_forecasts")
}

enum PaymentMethod {
  Cash
  Credit
  BankTransfer
  Sales
  Padan
}

enum PaymentStatus {
  Paid
  Pending
  Partial
  Overdue
}

enum DeliveryStatus {
  Planned
  InProgress
  Completed
  Cancelled
}

enum StoreType {
  Market
  Store
}

enum OrderType {
  Market
  Store
}

model ProductPrice {
  id              Int          @id @default(autoincrement())
  productId       Int          @map("product_id")
  customerTypeId  Int          @map("customer_type_id")
  price           Decimal      @db.Decimal(10, 2)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerType    CustomerType @relation(fields: [customerTypeId], references: [id])

  @@unique([productId, customerTypeId])
  @@map("product_prices")
}
