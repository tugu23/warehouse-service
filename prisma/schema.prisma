// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  Cash
  Credit
  BankTransfer
  Sales
  Padan
}

enum PaymentStatus {
  Paid
  Pending
  Partial
  Overdue
}

enum DeliveryStatus {
  Planned
  InProgress
  Completed
  Cancelled
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(50)
  employees Employee[]

  @@map("roles")
}

model Employee {
  id            Int              @id @default(autoincrement())
  name          String           @db.VarChar(255)
  email         String           @unique @db.VarChar(255)
  phoneNumber   String?          @map("phone_number") @db.VarChar(50)
  passwordHash  String           @map("password_hash") @db.VarChar(255)
  roleId        Int              @map("role_id")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  
  role          Role             @relation(fields: [roleId], references: [id])
  orders        Order[]          @relation("AgentOrders")
  customers     Customer[]       @relation("AssignedAgent")
  locations     AgentLocation[]
  deliveryPlans DeliveryPlan[]

  @@map("employees")
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  contactInfo String?   @map("contact_info") @db.Text
  products    Product[]

  @@map("suppliers")
}

model Category {
  id            Int       @id @default(autoincrement())
  nameMongolian String    @map("name_mongolian") @db.VarChar(255)
  nameEnglish   String?   @map("name_english") @db.VarChar(255)
  description   String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  products      Product[]

  @@map("categories")
}

model Product {
  id             Int          @id @default(autoincrement())
  nameMongolian  String       @map("name_mongolian") @db.VarChar(255)
  nameEnglish    String?      @map("name_english") @db.VarChar(255)
  productCode    String?      @unique @map("product_code") @db.VarChar(100)
  supplierId     Int?         @map("supplier_id")
  categoryId     Int?         @map("category_id")
  stockQuantity  Int          @default(0) @map("stock_quantity")
  priceWholesale Decimal?     @map("price_wholesale") @db.Decimal(10, 2)
  priceRetail    Decimal?     @map("price_retail") @db.Decimal(10, 2)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])
  category       Category?    @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  returns        Return[]
  batches        ProductBatch[]
  inventoryBalances InventoryBalance[]

  @@map("products")
}

model CustomerType {
  id        Int        @id @default(autoincrement())
  typeName  String     @map("type_name") @db.VarChar(100)
  customers Customer[]

  @@map("customer_types")
}

model Customer {
  id                   Int           @id @default(autoincrement())
  name                 String        @db.VarChar(255)
  address              String?       @db.Text
  phoneNumber          String?       @map("phone_number") @db.VarChar(50)
  locationLatitude     Float?        @map("location_latitude")
  locationLongitude    Float?        @map("location_longitude")
  customerTypeId       Int?          @map("customer_type_id")
  assignedAgentId      Int?          @map("assigned_agent_id")
  
  customerType         CustomerType? @relation(fields: [customerTypeId], references: [id])
  assignedAgent        Employee?     @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  orders               Order[]
  deliveryPlans        DeliveryPlan[]

  @@map("customers")
}

model Order {
  id               Int            @id @default(autoincrement())
  customerId       Int            @map("customer_id")
  agentId          Int            @map("agent_id")
  orderDate        DateTime       @default(now()) @map("order_date") @db.Timestamptz(3)
  status           String         @default("Pending") @db.VarChar(50)
  totalAmount      Decimal?       @map("total_amount") @db.Decimal(12, 2)
  paymentMethod    PaymentMethod  @default(Cash) @map("payment_method")
  paymentStatus    PaymentStatus  @default(Pending) @map("payment_status")
  creditTermDays   Int?           @map("credit_term_days")
  dueDate          DateTime?      @map("due_date") @db.Timestamptz(3)
  paidAmount       Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  remainingAmount  Decimal?       @map("remaining_amount") @db.Decimal(12, 2)
  deliveryPlanId   Int?           @map("delivery_plan_id")
  
  customer         Customer       @relation(fields: [customerId], references: [id])
  agent            Employee       @relation("AgentOrders", fields: [agentId], references: [id])
  orderItems       OrderItem[]
  returns          Return[]
  payments         Payment[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Return {
  id         Int      @id @default(autoincrement())
  orderId    Int      @map("order_id")
  productId  Int      @map("product_id")
  quantity   Int
  reason     String?  @db.Text
  returnDate DateTime @default(now()) @map("return_date") @db.Timestamptz(3)
  
  order      Order    @relation(fields: [orderId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("returns")
}

model AgentLocation {
  id        Int      @id @default(autoincrement())
  agentId   Int      @map("agent_id")
  latitude  Float
  longitude Float
  timestamp DateTime @default(now()) @db.Timestamptz(3)
  
  agent     Employee @relation(fields: [agentId], references: [id])

  @@map("agent_locations")
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @map("order_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @default(now()) @map("payment_date") @db.Timestamptz(3)
  paymentMethod PaymentMethod @map("payment_method")
  notes         String?       @db.Text
  
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ProductBatch {
  id              Int       @id @default(autoincrement())
  productId       Int       @map("product_id")
  batchNumber     String    @map("batch_number") @db.VarChar(100)
  arrivalDate     DateTime  @map("arrival_date") @db.Timestamptz(3)
  expiryDate      DateTime? @map("expiry_date") @db.Timestamptz(3)
  quantity        Int
  costPrice       Decimal?  @map("cost_price") @db.Decimal(10, 2)
  supplierInvoice String?   @map("supplier_invoice") @db.VarChar(255)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, batchNumber])
  @@map("product_batches")
}

model InventoryBalance {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  month          Int
  year           Int
  openingBalance Int      @default(0) @map("opening_balance")
  closingBalance Int      @default(0) @map("closing_balance")
  totalIn        Int      @default(0) @map("total_in")
  totalOut       Int      @default(0) @map("total_out")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, month, year])
  @@map("inventory_balances")
}

model DeliveryPlan {
  id                  Int            @id @default(autoincrement())
  planDate            DateTime       @map("plan_date") @db.Timestamptz(3)
  agentId             Int            @map("agent_id")
  customerId          Int            @map("customer_id")
  orderId             Int?           @map("order_id")
  scheduledTime       DateTime?      @map("scheduled_time") @db.Timestamptz(3)
  status              DeliveryStatus @default(Planned)
  deliveryNotes       String?        @map("delivery_notes") @db.Text
  actualDeliveryTime  DateTime?      @map("actual_delivery_time") @db.Timestamptz(3)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  
  agent               Employee       @relation(fields: [agentId], references: [id])
  customer            Customer       @relation(fields: [customerId], references: [id])

  @@map("delivery_plans")
}

